#!/bin/sh
set -e

# Create config directory
mkdir -p /etc/punchd-vpn

# Reload systemd
systemctl daemon-reload

# Enable service (don't start — no config yet)
systemctl enable punchd-vpn || true

echo ""
echo "Punchd VPN installed."
echo "Configure: /etc/punchd-vpn/vpn-config.toml"
echo "Start:     systemctl start punchd-vpn"
echo "Logs:      journalctl -u punchd-vpn -f"
