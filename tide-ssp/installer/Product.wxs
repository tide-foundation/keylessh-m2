<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="TideSSP"
           Manufacturer="Tide Foundation"
           Version="1.0.0.0"
           UpgradeCode="A3F1B7D2-4E6C-4A8F-9B2D-1C5E3F7A9D0B"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of TideSSP is already installed."
                  Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" />

    <!-- Require elevated privileges -->
    <Launch Condition="Privileged" Message="This installer requires administrator privileges." />

    <!-- Properties -->
    <Property Id="ARPNOREPAIR" Value="yes" Secure="yes" />
    <Property Id="TIDE_CONFIG_FILE" Secure="yes" />
    <Property Id="WIXUI_INSTALLDIR" Value="System64Folder" />

    <!-- Directory layout -->
    <StandardDirectory Id="System64Folder">
      <Component Id="TideSSP_DLL" Guid="B1C2D3E4-F5A6-47B8-9C0D-1E2F3A4B5C6D">
        <File Id="TideSSP.dll" Source="!(bindpath.BinDir)\TideSSP.dll" KeyPath="yes" />
      </Component>
      <Component Id="TideSubAuth_DLL" Guid="C2D3E4F5-A6B7-48C9-0D1E-2F3A4B5C6D7E">
        <File Id="TideSubAuth.dll" Source="!(bindpath.BinDir)\TideSubAuth.dll" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Feature -->
    <Feature Id="Complete" Title="TideSSP" Level="1">
      <ComponentRef Id="TideSSP_DLL" />
      <ComponentRef Id="TideSubAuth_DLL" />
    </Feature>

    <!-- Custom actions DLL -->
    <Binary Id="TideCA" SourceFile="!(bindpath.BinDir)\TideCA.dll" />

    <!-- Immediate CA: validate config file exists and is valid JSON with jwk.keys -->
    <CustomAction Id="CA_ValidateConfig"
                  DllEntry="ValidateConfig"
                  BinaryRef="TideCA"
                  Execute="immediate"
                  Return="check" />

    <!-- Pass config file path to deferred CA -->
    <CustomAction Id="CA_SetWriteConfigData"
                  Property="CA_WriteConfig"
                  Value="[TIDE_CONFIG_FILE]" />

    <!-- Deferred CA: read file and write JSON to registry -->
    <CustomAction Id="CA_WriteConfig"
                  DllEntry="WriteConfig"
                  BinaryRef="TideCA"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- Install custom actions -->
    <CustomAction Id="CA_RegisterSecurityPackage"
                  DllEntry="RegisterSecurityPackage"
                  BinaryRef="TideCA"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="CA_RegisterSubAuth"
                  DllEntry="RegisterSubAuth"
                  BinaryRef="TideCA"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- Uninstall custom actions -->
    <CustomAction Id="CA_UnregisterSecurityPackage"
                  DllEntry="UnregisterSecurityPackage"
                  BinaryRef="TideCA"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="CA_UnregisterSubAuth"
                  DllEntry="UnregisterSubAuth"
                  BinaryRef="TideCA"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="CA_ClearMnsFlags"
                  DllEntry="ClearMnsFlags"
                  BinaryRef="TideCA"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="CA_RemoveConfig"
                  DllEntry="RemoveConfig"
                  BinaryRef="TideCA"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ═══════════════════════════════════════════════════════
         Installer UI — Config file selection dialog
         ═══════════════════════════════════════════════════════ -->
    <UI>
      <!-- Dialog: Welcome -->
      <Dialog Id="WelcomeDlg" Width="370" Height="270" Title="TideSSP Setup">
        <Control Id="Title" Type="Text" X="20" Y="20" Width="330" Height="30"
                 Text="{\WixUI_Font_Title}Welcome to TideSSP Setup" />
        <Control Id="Description" Type="Text" X="20" Y="55" Width="330" Height="40"
                 Text="This will install TideSSP for passwordless Ed25519 RDP authentication. You will need your TideCloak configuration file (tidecloak.json)." />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17"
                 Default="yes" Text="Next">
          <Publish Event="NewDialog" Value="ConfigDlg" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17"
                 Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Dialog: TideCloak Config File -->
      <Dialog Id="ConfigDlg" Width="370" Height="270" Title="TideSSP Setup — TideCloak Configuration">
        <Control Id="Title" Type="Text" X="20" Y="20" Width="330" Height="20"
                 Text="{\WixUI_Font_Title}TideCloak Configuration" />
        <Control Id="Description" Type="Text" X="20" Y="45" Width="330" Height="30"
                 Text="Select your tidecloak.json file. This contains the Ed25519 public key used to verify RDP authentication tokens." />

        <Control Id="PathLabel" Type="Text" X="20" Y="85" Width="330" Height="12"
                 Text="Path to tidecloak.json:" />
        <Control Id="ConfigPath" Type="PathEdit" X="20" Y="100" Width="270" Height="18"
                 Property="TIDE_CONFIG_FILE" />
        <Control Id="BrowseBtn" Type="PushButton" X="296" Y="100" Width="56" Height="18"
                 Text="Browse...">
          <Publish Event="SpawnDialog" Value="BrowseDlg" />
        </Control>

        <Control Id="Hint" Type="Text" X="20" Y="130" Width="330" Height="30"
                 Text="You can export this file from TideCloak Admin Console (Clients → your client → Installation tab). Or pass it via command line: msiexec /i TideSSP.msi TIDE_CONFIG_FILE=&quot;C:\path\to\tidecloak.json&quot;" />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17"
                 Text="Back">
          <Publish Event="NewDialog" Value="WelcomeDlg" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17"
                 Default="yes" Text="Install">
          <!-- Validate before proceeding -->
          <Publish Event="DoAction" Value="CA_ValidateConfig" Order="1" />
          <Publish Event="EndDialog" Value="Return" Order="2">
            <![CDATA[TIDE_CONFIG_FILE <> ""]]>
          </Publish>
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17"
                 Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!-- Cancel confirmation dialog -->
      <Dialog Id="CancelDlg" Width="260" Height="85" Title="Cancel Setup">
        <Control Id="Text" Type="Text" X="48" Y="15" Width="194" Height="30"
                 Text="Are you sure you want to cancel TideSSP installation?" />
        <Control Id="Yes" Type="PushButton" X="72" Y="57" Width="56" Height="17"
                 Text="Yes">
          <Publish Event="EndDialog" Value="Exit" />
        </Control>
        <Control Id="No" Type="PushButton" X="132" Y="57" Width="56" Height="17"
                 Cancel="yes" Default="yes" Text="No">
          <Publish Event="EndDialog" Value="Return" />
        </Control>
      </Dialog>

      <!-- Completion dialog -->
      <Dialog Id="ExitDlg" Width="370" Height="270" Title="TideSSP Setup Complete">
        <Control Id="Title" Type="Text" X="20" Y="20" Width="330" Height="30"
                 Text="{\WixUI_Font_Title}TideSSP Installation Complete" />
        <Control Id="Description" Type="Text" X="20" Y="55" Width="330" Height="40"
                 Text="TideSSP has been installed. A reboot is required to activate the security provider. After reboot, RDP logons via the gateway will be passwordless." />
        <Control Id="Finish" Type="PushButton" X="304" Y="243" Width="56" Height="17"
                 Default="yes" Cancel="yes" Text="Finish">
          <Publish Event="EndDialog" Value="Return" />
        </Control>
      </Dialog>

      <!-- Standard file browse dialog -->
      <Property Id="BROWSE_PROPERTY" Value="TIDE_CONFIG_FILE" />

      <!-- Install dialog sequence -->
      <InstallUISequence>
        <Show Dialog="WelcomeDlg" Before="ExecuteAction"
              Condition="NOT Installed" />
        <Show Dialog="ExitDlg" After="ExecuteAction"
              Condition="NOT Installed" />
      </InstallUISequence>

      <!-- Text styles -->
      <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="10" Bold="yes" />
    </UI>

    <InstallExecuteSequence>
      <!-- Write config on install -->
      <Custom Action="CA_SetWriteConfigData" After="InstallFiles"
              Condition="NOT Installed" />
      <Custom Action="CA_WriteConfig" After="CA_SetWriteConfigData"
              Condition="NOT Installed" />

      <!-- Register on install -->
      <Custom Action="CA_RegisterSecurityPackage" After="CA_WriteConfig"
              Condition="NOT Installed" />
      <Custom Action="CA_RegisterSubAuth" After="CA_RegisterSecurityPackage"
              Condition="NOT Installed" />

      <!-- Unregister on uninstall -->
      <Custom Action="CA_UnregisterSecurityPackage" Before="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_UnregisterSubAuth" After="CA_UnregisterSecurityPackage"
              Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_ClearMnsFlags" After="CA_UnregisterSubAuth"
              Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="CA_RemoveConfig" After="CA_ClearMnsFlags"
              Condition="REMOVE=&quot;ALL&quot;" />

      <!-- Schedule reboot -->
      <ScheduleReboot After="InstallFinalize" />
    </InstallExecuteSequence>

  </Package>
</Wix>
