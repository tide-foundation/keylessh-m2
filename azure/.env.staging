# KeyleSSH Staging Environment Configuration
# Committed template — real secrets live in .env.staging.local (gitignored)
# Deploy with: DEPLOY_ENV=staging ./azure/deploy-devops.sh --setup|--gateway|--all

# ─── Azure Resources ────────────────────────────────────────
RESOURCE_GROUP=KeyleSSH
LOCATION=australiaeast
STORAGE_ACCOUNT=keylesshstorage

# ─── Web App ────────────────────────────────────────────────
WEBAPP_NAME=keylessh-staging
APP_SERVICE_PLAN=keylessh-plan
FILE_SHARE=keylessh-staging
SERVER_URL=https://staging.keylessh.com

# ─── Punchd Gateway (ACI) ──────────────────────────────────
ACI_NAME=punchd-gateway-staging
DNS_LABEL=punchd-gateway-staging
GATEWAY_IMAGE=tideorg/punchd-gateway:latest
GATEWAY_ID=Staging-GW
GATEWAY_DISPLAY_NAME=Staging Gateway

# ─── Signal Server (REQUIRED — set secrets in .env.staging.local) ──
# Staging reuses the shared signal/STUN/TURN server.
STUN_SERVER_URL=wss://punchd.keylessh.com
API_SECRET=REPLACE_ME
TURN_SECRET=REPLACE_ME
EXTERNAL_IP=REPLACE_ME

# ─── ICE/TURN (derived from EXTERNAL_IP) ───────────────────
# ICE_SERVERS=stun:${EXTERNAL_IP}:3478
# TURN_SERVER=turn:${EXTERNAL_IP}:3478

# ─── Backends (SSH targets for the gateway) ─────────────────
# Format: Name=protocol://host:port, comma-separated. Set in .env.staging.local.

# ─── TideCloak ──────────────────────────────────────────────
# Staging uses its own identity server + realm (not prod login.dauth.me).
AUTH_SERVER_PUBLIC_URL=https://staging.dauth.me
# TIDECLOAK_CONFIG auto-selects data/tidecloak.staging.json when present
# (exported from the staging.dauth.me realm). Falls back to data/tidecloak.json.
