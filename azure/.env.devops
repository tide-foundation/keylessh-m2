# KeyleSSH DevOps Environment Configuration
# Copy this to .env.devops and fill in the values

# ─── Azure Resources ────────────────────────────────────────
RESOURCE_GROUP=KeyleSSH
LOCATION=australiaeast
STORAGE_ACCOUNT=keylesshstorage

# ─── Web App ────────────────────────────────────────────────
WEBAPP_NAME=keylessh-devops
APP_SERVICE_PLAN=keylessh-plan
FILE_SHARE=keylessh-devops
SERVER_URL=https://devops.keylessh.com

# ─── Punchd Gateway (ACI) ──────────────────────────────────
ACI_NAME=punchd-gateway-devops
DNS_LABEL=punchd-gateway-devops
GATEWAY_IMAGE=tideorg/punchd-gateway:latest
GATEWAY_ID=Devops-GW
GATEWAY_DISPLAY_NAME=Devops Gateway

# ─── Signal Server (REQUIRED) ──────────────────────────────
# Get these from your signal-server-rs/.env
STUN_SERVER_URL=wss://signal.keylessh.com:9090
API_SECRET=REPLACE_ME
TURN_SECRET=REPLACE_ME
EXTERNAL_IP=REPLACE_ME

# ─── ICE/TURN (derived from EXTERNAL_IP) ───────────────────
# ICE_SERVERS=stun:${EXTERNAL_IP}:3478
# TURN_SERVER=turn:${EXTERNAL_IP}:3478

# ─── Backends (SSH targets for the gateway) ─────────────────
# Format: Name=protocol://host:port, comma-separated for multiple
# BACKENDS=SSH Server=ssh://10.0.0.4

# ─── TideCloak ──────────────────────────────────────────────
AUTH_SERVER_PUBLIC_URL=https://login.dauth.me
TIDECLOAK_CONFIG=../data/tidecloak.json
